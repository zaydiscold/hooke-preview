# Nebius Token Factory (LLM — heavy research / synthesis)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# OpenRouter — fast orchestration, paper analysis, abstract enrichment via Perplexity Sonar
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FAST_MODEL=google/gemini-2.5-flash

# Tavily web search
TAVILY_API_KEY=

# Google API key for AlphaGenome
GOOGLE_API_KEY=

# Semantic Scholar (optional) — raises rate limit from 100 req/5 min to 1 req/s
# Free key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# PubMed + app settings
PUBMED_EMAIL=hooke-bio@users.noreply.github.com
REQUEST_TIMEOUT_SECONDS=30
APP_PORT=8000
